# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/intellici
REDIS_URL=redis://localhost:6379/0

# ── Auth ────────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-32-char-hex-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── GitHub ──────────────────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# ── LLM Provider ────────────────────────────────────────────────────────────────
# Supported: openai | ollama | none (rule-based fallback)
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── ML Engine ───────────────────────────────────────────────────────────────────
ML_MODEL_PATH=ml-engine/models/model.pkl
DECISION_THRESHOLD_RUN=0.55
DECISION_THRESHOLD_PARTIAL=0.30
